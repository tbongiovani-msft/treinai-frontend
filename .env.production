VITE_FUNC_ATIVIDADES=https://treinai-func-atividades-dev.azurewebsites.net
VITE_FUNC_AVALIACOES=https://treinai-func-avaliacoes-dev.azurewebsites.net
VITE_FUNC_NUTRICAO=https://treinai-func-nutricao-dev.azurewebsites.net
VITE_FUNC_RELATORIOS=https://treinai-func-relatorios-dev.azurewebsites.net
VITE_FUNC_ADMIN=https://treinai-func-admin-dev.azurewebsites.net
