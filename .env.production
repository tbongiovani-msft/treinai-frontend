# ──────────────────────────────────────────────
# treinAI Frontend — Azure (dev environment)
# ──────────────────────────────────────────────
# These URLs point to the individual Azure Function Apps.
# The SWA build injects them at build time (VITE_ prefix required).
#
# Convention: https://treinai-func-{service}-dev.azurewebsites.net
# ──────────────────────────────────────────────

VITE_FUNC_ALUNOS=https://treinai-func-alunos-dev.azurewebsites.net
VITE_FUNC_TREINOS=https://treinai-func-treinos-dev.azurewebsites.net
VITE_FUNC_ATIVIDADES=https://treinai-func-atividades-dev.azurewebsites.net
VITE_FUNC_AVALIACOES=https://treinai-func-avaliacoes-dev.azurewebsites.net
VITE_FUNC_NUTRICAO=https://treinai-func-nutricao-dev.azurewebsites.net
VITE_FUNC_RELATORIOS=https://treinai-func-relatorios-dev.azurewebsites.net
VITE_FUNC_ADMIN=https://treinai-func-admin-dev.azurewebsites.net

# Auth provider: 'mock' for dev testing, 'aadb2c' for production Azure AD B2C
# Switch to 'aadb2c' after B2C tenant is configured (E15-07)
VITE_AUTH_PROVIDER=mock
